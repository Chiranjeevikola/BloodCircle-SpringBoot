# ===== BloodCircle Environment Variables =====

# Spring Boot Profile (dev / prod)
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL Database (production)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bloodcircle
SPRING_DATASOURCE_USERNAME=bloodcircle
SPRING_DATASOURCE_PASSWORD=your-password-here

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production-must-be-at-least-256-bits

# Admin Seed
ADMIN_EMAIL=chiranjeevi.kola@zohomail.in
ADMIN_PASSWORD=change-in-production
